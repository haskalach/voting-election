## Example: TypeScript with Jasmine

```
Context & Requirements
======================

Project: Election Voting frontend (Angular 18, TypeScript 5)
Class/Component: EmployeesService
File: frontend/src/app/core/services/employees.service.ts
Language: TypeScript
Test Framework: Jasmine
Standards Reference: .instructions-frontend.md
Target Coverage: 95%

Methods to Test
===============

Test these methods:
- createEmployee(dto: CreateEmployeeDto): Observable<EmployeeDto>
- getEmployeeById(id: number): Observable<EmployeeDto>
- updateEmployee(id: number, dto: UpdateEmployeeDto): Observable<EmployeeDto>
- deleteEmployee(id: number): Observable<void>
- listEmployees(organizationId: number): Observable<EmployeeDto[]>

Test Scenarios
==============

Edge Cases:
- HTTP 404 not found error
- Network timeout
- Invalid response format
- Empty employee list
- Concurrent requests
```

### Expected Test Output

```typescript
describe('EmployeesService', () => {
  let service: EmployeesService;
  let httpMock: HttpTestingController;

  beforeEach(() => {
    TestBed.configureTestingModule({
      imports: [HttpClientTestingModule],
      providers: [EmployeesService]
    });
    service = TestBed.inject(EmployeesService);
    httpMock = TestBed.inject(HttpTestingController);
  });

  afterEach(() => {
    httpMock.verify();
  });

  // Happy Path
  it('should create employee', () => {
    const dto: CreateEmployeeDto = {
      firstName: 'John',
      lastName: 'Doe',
      email: 'john@example.com'
    };
    const expected: EmployeeDto = { id: 1, ...dto };

    service.createEmployee(dto).subscribe(result => {
      expect(result).toEqual(expected);
    });

    const req = httpMock.expectOne('api/employees');
    expect(req.request.method).toBe('POST');
    req.flush(expected);
  });

  // Error Case: 404 Not Found
  it('should handle not found error', () => {
    service.getEmployeeById(999).subscribe(
      () => fail('should have failed'),
      (error: HttpErrorResponse) => {
        expect(error.status).toBe(404);
      }
    );

    const req = httpMock.expectOne('api/employees/999');
    req.flush('Not found', { status: 404, statusText: 'Not Found' });
  });

  // Edge Case: Empty list
  it('should return empty array for no employees', () => {
    const expected: EmployeeDto[] = [];

    service.listEmployees(1).subscribe(result => {
      expect(result.length).toBe(0);
    });

    const req = httpMock.expectOne('api/organizations/1/employees');
    req.flush(expected);
  });
});
```

