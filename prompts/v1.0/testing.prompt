## Example: C# with xUnit

```
Context & Requirements
======================

Project: Election Voting backend (.NET Core 10, clean architecture)
Class/Component: EmployeeService
File: backend/ElectionVoting.Application/Services/EmployeeService.cs
Language: C#
Test Framework: xUnit
Standards Reference: .instructions-backend.md
Target Coverage: 95%

Methods to Test
===============

Test these methods/functions:
- CreateEmployeeAsync(CreateEmployeeDto) → Task<EmployeeDto>
- GetEmployeeByIdAsync(int) → Task<EmployeeDto>
- UpdateEmployeeAsync(int, UpdateEmployeeDto) → Task<EmployeeDto>
- DeleteEmployeeAsync(int) → Task<void>
- ListEmployeesByOrganizationAsync(int) → Task<IEnumerable<EmployeeDto>>

Test Scenarios
==============

Edge Cases:
- Null email / empty email
- Email already exists (duplicate)
- Employee ID not found (404)
- Organization ID mismatch (unauthorized)
- Very long names (boundary)
- Concurrent requests (race condition)
```

### Expected Test Class Output

```csharp
public class EmployeeServiceTests
{
    private readonly IEmployeeRepository _employeeRepository;
    private readonly IMapper _mapper;
    private readonly EmployeeService _sut; // System Under Test
    
    public EmployeeServiceTests()
    {
        _employeeRepository = Substitute.For<IEmployeeRepository>();
        _mapper = Substitute.For<IMapper>();
        _sut = new EmployeeService(_employeeRepository, _mapper);
    }
    
    // Happy Path
    [Fact]
    public async Task CreateEmployeeAsync_WithValidEmail_ReturnsEmployeeDto()
    {
        // Arrange
        var dto = new CreateEmployeeDto("John Doe", "john@election.com", 1);
        var employee = new Employee("John Doe", "john@election.com", 1, 1);
        var employeeDto = new EmployeeDto(1, "John Doe", "john@election.com");
        
        _employeeRepository.AddAsync(Arg.Any<Employee>()).Returns(employee);
        _mapper.Map<EmployeeDto>(employee).Returns(employeeDto);
        
        // Act
        var result = await _sut.CreateEmployeeAsync(dto);
        
        // Assert
        result.Should().NotBeNull();
        result.Email.Should().Be("john@election.com");
        await _employeeRepository.Received().AddAsync(Arg.Any<Employee>());
    }
    
    // Edge Case: Email already exists
    [Fact]
    public async Task CreateEmployeeAsync_WithDuplicateEmail_ThrowsInvalidOperationException()
    {
        // Arrange
        var dto = new CreateEmployeeDto("Jane Doe", "existing@election.com", 1);
        _employeeRepository.AddAsync(Arg.Any<Employee>())
            .Throws(new InvalidOperationException("Email already exists"));
        
        // Act & Assert
        await Assert.ThrowsAsync<InvalidOperationException>(
            () => _sut.CreateEmployeeAsync(dto));
    }
    
    // Error Case: Organization not found
    [Fact]
    public async Task GetEmployeeByIdAsync_WithInvalidId_ThrowsKeyNotFoundException()
    {
        // Arrange
        _employeeRepository.GetByIdAsync(999).Returns((Employee)null);
        
        // Act & Assert
        await Assert.ThrowsAsync<KeyNotFoundException>(
            () => _sut.GetEmployeeByIdAsync(999));
    }
}
```

